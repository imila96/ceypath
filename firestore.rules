rules_version = '2';
// Shared Firebase project may also serve a mobile app (e.g. sounds / stories).
// Deploy these rules in Firebase Console so web + mobile both work; tighten before public launch if needed.
service cloud.firestore {
  match /databases/{database}/documents {

    // Web: shared tour catalog JSON (document id is usually `catalog`).
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Mobile app collections (same project — no overlap with `settings/catalog`).
    match /sounds/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /stories/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
