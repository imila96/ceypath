# Data mode: dummy | real | hybrid
# - dummy: fixtures only (src/data/*) — default for demos
# - real: API when implemented (Phase B+); until then dev console notes fixtures still used
# - hybrid: API first, fixtures as fallback (Phase C+)
VITE_DATA_MODE=dummy

# Backend origin, no trailing slash (Phase B+)
# When set, catalog GETs are used in real/hybrid mode, e.g.:
#   GET {VITE_API_BASE_URL}/packages
#   GET {VITE_API_BASE_URL}/destinations
#   GET {VITE_API_BASE_URL}/vehicles
# VITE_API_BASE_URL=https://api.example.com

# Cloudinary (unsigned upload preset — safe to expose in frontend)
# Defaults match the project preset; set VITE_CLOUDINARY_UPLOAD_PRESET= to force embedded images only (no network upload).
# VITE_CLOUDINARY_CLOUD_NAME=dbgrjduzy
# VITE_CLOUDINARY_UPLOAD_PRESET=web_project_uploads
# VITE_CLOUDINARY_FOLDER=web_uploads
